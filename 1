model_ols <- plm(
  lscrap ~ tothrs + d88 + d89 + grant + grant_1,
  data=JTRAIN,
  index=c("fcode","year"),
  model="pooling"
)
summary(model_ols)

model_fe <- plm(
  lscrap ~ tothrs + d88 + d89 + grant + grant_1,
  data=JTRAIN,
  index=c("fcode","year"),
  model="within",
  effect="individual"
)
summary(model_fe)

fixef(model_fe, type="dmean")

model_re <- plm(
  lscrap ~ tothrs + d88 + d89 + grant + grant_1,
  data=JTRAIN,
  index=c("fcode","year"),
  model="random",
  random.method="walhus"
)
summary(model_re)

phtest(model_fe, model_re)

model_be <- update(model_ols, model="between")
summary(model_be)

JTRAIN <- JTRAIN %>%
  group_by(fcode) %>%
  mutate(
    dlscrap = lscrap - lag(lscrap),
    dtothrs = tothrs - lag(tothrs),
    dgrant = grant - lag(grant)
  )

model_fd <- lm(dlscrap ~ dtothrs + dgrant, data=JTRAIN)
summary(model_fd)

model_dv <- plm(
  lscrap ~ tothrs + factor(fcode),
  data=JTRAIN,
  index=c("fcode","year"),
  model="pooling"
)
summary(model_dv)
