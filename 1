# =========================================================
# 2 · D O W N L O A D  S T O C K  D A T A
# =========================================================

# single stock
stock = yf.download("RELIANCE.NS", start='2019-01-01', end='2024-12-31')

# multiple tickers (loop)
tickers = ['RELIANCE.NS', 'ASIANPAINT.NS', 'M&M.NS', 'AXISBANK.NS']
pf = pd.DataFrame()
for t in tickers:
    pf[t] = yf.download(t, start='2020-01-01', end='2026-03-01')['Close']


# =========================================================
# 3 · D A T A  P R E P  &  S L I C I N G
# =========================================================

# keep OHLCV columns
stock = stock[['Open','High','Low','Close','Volume']]
stock.columns = ['Open','High','Low','Close','Volume']

# time slices
# trading days: ~252/yr, 63/qtr
last3m = stock.tail(63)
last6m = stock.tail(126)
last1y = stock.tail(252)

# 63 = 3 months · 126 = 6 months · 252 = 1 year of trading days

# resample to weekly
weekly = stock.resample('W').agg({
    'Open' : 'first',
    'High' : 'max',
    'Low' : 'min',
    'Close' : 'last',
    'Volume': 'sum'
})

# Aggregates daily bars into weekly OHLCV bars. Use 'M' for monthly.


