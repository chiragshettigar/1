# basic candle
mpf.plot(stock_last3m, type='candle', volume=True)

# Requires DataFrame with Open/High/Low/Close/Volume and a DatetimeIndex.

# custom style + moving averages
mc = mpf.make_marketcolors(
    up='Green',
