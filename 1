)

style = mpf.make_mpf_style(
    base_mpf_style='classic',
    marketcolors=mc,
    facecolor='white',
    gridcolor='black'
)

mpf.plot(
    stock_last1y,
    type='candle',
    style=style,
    title="RELIANCE OHLC Chart",
    xlabel='dates',
    ylabel='Prices',
    figratio=(12,6),
    figscale=1.2,
    figsize=(10,6),
    volume=True,
    mav=[10,20,30],
    mavcolors=['purple','pink','violet']
)

# mav = moving average windows · figratio = aspect ratio


# =========================================================
# 6 · R S I — R E L A T I V E  S T R E N G T H  I N D E X
# =========================================================

# calculate RSI (14-day)
delta = stock_last1y['Close'].diff()

# separate gains and losses
gain = delta.clip(lower=0)
loss = -delta.clip(upper=0)

# 14-period rolling averages
avg_gain = gain.rolling(14).mean()
avg_loss = loss.rolling(14).mean()

rs = avg_gain / avg_loss
stock_last1y['RSI'] = 100 - (100 / (1 + rs))

# RSI > 70 = overbought · RSI < 30 = oversold

# plot RSI as addplot panel
apds = [
    mpf.make_addplot(stock_last1y['RSI'], panel=1, color='hotpink'),
    mpf.make_addplot([70]*len(stock_last1y), panel=1, color='red', linestyle='--'),
    mpf.make_addplot([30]*len(stock_last1y), panel=1, color='green', linestyle='--')
]

mpf.plot(
    stock_last1y,
    type='candle',
    style=style,
    addplot=apds,
    panel_ratios=(3,1,1),
    volume=True,
    volume_panel=2,
    figsize=(10,7),
    mav=[20,50],
    mavcolors=['purple','hotpink']
)

# panel=0 = candle · panel=1 = RSI · panel=2 = volume


# =========================================================
# 7 · R E T U R N S  &  L O G  R E T U R N S
# =========================================================

# simple return (Pt / Pt-1) - 1
df['return'] = (df['Close'] / df['Close'].shift(1)) - 1

# log return ln(Pt / Pt-1)
df['log_return'] = np.log(df['Close'] / df['Close'].shift(1))

# portfolio returns (multiple stocks)
pf_returns = (pf / pf.shift(1)) - 1

# select 2 stocks
pf_returns = pf_returns[["RELIANCE.NS", "M&M.NS"]]


# =========================================================
# 8 · R I S K — S T D  D E V  &  V A R I A N C E
# =========================================================

# daily std dev
pf_returns['RELIANCE.NS'].std()

# daily variance
pf_returns['RELIANCE.NS'].var()

# annualise
pf_returns['RELIANCE.NS'].std() * 252**0.5
pf_returns['RELIANCE.NS'].var() * 252

# covariance & correlation
cov_matrix = pf_returns.cov()
corr_matrix = pf_returns.corr()

# annualised covariance
cov_matrix_annual = pf_returns.cov() * 252


# =========================================================
# 9 · P O R T F O L I O  R E T U R N  &  V O L A T I L I T Y
# =========================================================

# define weights
weights_1 = np.array([0.5, 0.5])
weights_2 = np.array([0.3, 0.7])

# expected return
trial = (pf_returns[['RELIANCE.NS','M&M.NS']].mean()) * 252

R_p = np.dot(weights_1, trial)
print(f"{round(R_p*100,3)}%")

# alternative
np.dot(pf_returns.mean()*252, weights_1)

# portfolio variance
pf_var = np.dot(
    weights_1.T,
    np.dot(pf_returns.cov()*252, weights_1)
)

# portfolio volatility
pf_vol = (np.dot(
    weights_1.T,
    np.dot(pf_returns.cov()*252, weights_1)
)) ** 0.5

print(str(round(pf_vol, 5) * 100) + "%")


